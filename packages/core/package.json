{
	"name": "@runstack-ai/hypermemory-core",
	"version": "1.0.0",
	"description": "HyperMemory client SDK — store, recall, and traverse hypergraphs",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"engines": { "node": ">=18.0.0" },
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	},
	"devDependencies": {
		"tsup": "^8.3.0",
		"typescript": "^5.6.0"
	},
	"keywords": ["hypermemory", "hypergraph", "memory", "api", "sdk"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/RunStack-AI/hypermemory-sdk.git",
		"directory": "packages/core"
	}
}
