{
	"name": "@runstack-ai/hypermemory-react",
	"version": "1.0.0",
	"description": "HyperMemory React 18+ components — graph visualization and client hooks",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0",
		"@runstack-ai/hypermemory-core": "workspace:*",
		"@runstack-ai/hypermemory-visualizer-core": "workspace:*"
	},
	"devDependencies": {
		"react": "^18.3.0",
		"react-dom": "^18.3.0",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"tsup": "^8.3.0",
		"typescript": "^5.6.0",
		"@runstack-ai/hypermemory-core": "workspace:*",
		"@runstack-ai/hypermemory-visualizer-core": "workspace:*"
	},
	"keywords": ["hypermemory", "react", "graph", "visualization"],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/RunStack-AI/hypermemory-sdk.git",
		"directory": "packages/react"
	}
}
